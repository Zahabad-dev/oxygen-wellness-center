PORT=3001
NODE_ENV=development

# Postgres (Easypanel). Usar el host INTERNO del servicio dentro del mismo proyecto de Easypanel,
# ej: postgres://oxygen_app:PASSWORD@<servicio-pg-interno>:5432/oxygen
DATABASE_URL=

JWT_SECRET=cambia-este-secreto-en-produccion
COOKIE_SECURE=0
CORS_ORIGINS=http://localhost:5173

UPLOAD_DIR=./uploads
CLIENT_DIST=../client/dist

# URL pública del sitio (usada al construir enlaces del QR / "mi-qr")
PUBLIC_URL=http://localhost:5173
